{
	// Place your snippets for oracle-sql here. Each snippet is defined under a snippet name and has a prefix, body and 
	// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
	// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the 
	// same ids are connected.
	// Example:ä
	// "Print to console": {
	// 	"prefix": "log",
	// 	"body": [
	// 		"console.log('$1');",
	// 		"$2"
	// 	],
	// 	"description": "Log output to console"
	// }
  "Declaration of Global Variable for Logger": {
    "prefix": "plglobal",
    "body": [
      "c_scope_prefix constant varchar2(50) := lower(\\$\\$plsql_unit) || '.';"
    ],
    "description": "Add a new global variable for logger"
  },
  "Declaration of Logger Variables": {
    "prefix": "pldeclare",
    "body": [
      "l_scope  logger_logs.scope%type := c_scope_prefix || '${1:procedure_name}';",
      "t_params logger.tab_param;"
    ],
    "description": "Add a new logger.log statement with parameter names included"
  },
  "Logger Append Param": {
    "prefix": "plparam",
    "body": [
      "logger.append_param('$1', $1);"
    ],
    "description": "Add a new logger.append_param statement"
  },
  "Logger Log": {
    "prefix": "pllog",
    "body": [
      "logger.log(p_text => '${1:START}', p_scope => l_scope, p_extra => ${2:null}, p_params => t_params);"
    ],
    "description": "Add a new logger.log statement with parameter names included"
  },
  "Logger Log Error with Extension Block": {
    "prefix": "plexc",
    "body": [
      "exception",
      "  when others",
      "  then",
      "    logger.log_error(p_text => 'Unhandled Error', p_scope => l_scope, p_extra => ${1:null}, p_params => t_params);",
    ],
    "description": "Add a new logger.log_error statement with exception block"
  },
  "Create Audit Header": {
    "prefix": "audit",
    "body": [
      "-- ################################################################",
      "-- # Author: Enter.your.name",
      "-- # Date: $CURRENT_YEAR-$CURRENT_MONTH-$CURRENT_DATE",
      "-- # Description: ${3:description}",
      "-- ################################################################"
    ],
    "description": "Create an audit header"
  },
  "Select Logger Logs records": {
    "prefix": "selectlogs",
    "body": [
      "select * ",
      "  from logger_logs",
      " where module like '${1}%'",
      " order by time_stamp desc;"
    ],
    "description": "Select records from logger_logs for a module"
  }
}